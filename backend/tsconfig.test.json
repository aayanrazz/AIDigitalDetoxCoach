{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "noEmit": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    "types": ["jest", "node"]
  },
  "include": [
    "tests/**/*.ts",
    "src/**/*.js",
    "src/**/*.json",
    "jest.system.config.cjs"
  ],
  "exclude": [
    "node_modules"
  ]
}