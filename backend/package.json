{
  "name": "detox-backend",
  "version": "1.0.0",
  "description": "Backend for AI-Powered Digital Detox Coach App",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seeds/seed.js",

    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --runInBand",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --watch",
    "test:integration:auth": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --runInBand src/__tests__/integration/auth.integration.test.js",

    "test:controllers": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers --runInBand",
    "test:controller:auth": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module01_auth_controller.test.ts --runInBand",
    "test:controller:profile": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module02_profile_setup_controller.test.ts --runInBand",
    "test:controller:settings": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module03_settings_preferences_controller.test.ts --runInBand",
    "test:controller:privacy": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module04_privacy_data_control_controller.test.ts --runInBand",
    "test:controller:usage-collection": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module05_usage_collection_controller.test.ts --runInBand",
    "test:controller:usage-today": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module06_usage_today_controller.test.ts --runInBand",
    "test:controller:usage-ml": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module07_usage_ml_controller.test.ts --runInBand",
    "test:controller:app-limits": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module08_app_limits_controller.test.ts --runInBand",
    "test:controller:dashboard": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module09_dashboard_controller.test.ts --runInBand",
    "test:controller:analytics": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module10_analytics_controller.test.ts --runInBand",
    "test:controller:detox-plan": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module11_detox_plan_controller.test.ts --runInBand",
    "test:controller:notifications-rewards": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/controllers/module12_notifications_rewards_controller.test.ts --runInBand",

    "test:ai": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs src/controllers/__tests__/usage.ml.controller.test.js src/controllers/__tests__/planPreview.ml.controller.test.js src/controllers/__tests__/notificationPreview.ml.controller.test.js tests/ai --runInBand",
    "test:ai:acceptance": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/acceptance --runInBand",
    "test:ai:smoke": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/smoke --runInBand",
    "test:ai:controllers": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs src/controllers/__tests__/usage.ml.controller.test.js src/controllers/__tests__/planPreview.ml.controller.test.js src/controllers/__tests__/notificationPreview.ml.controller.test.js --runInBand",
    "test:ai:artifacts": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/acceptance/model.artifacts.acceptance.test.js --runInBand",
    "test:ai:metrics": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/acceptance/model.metrics.acceptance.test.js --runInBand",
    "test:ai:risk-smoke": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/smoke/predict_risk_bridge.smoke.test.js --runInBand",
    "test:ai:plan-smoke": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/smoke/predict_plan_bridge.smoke.test.js --runInBand",
    "test:ai:notification-smoke": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.ai.config.cjs tests/ai/smoke/predict_notification_bridge.smoke.test.js --runInBand",

    "test:system": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.system.config.cjs --runInBand",
    "test:system:onboarding": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.system.config.cjs tests/system/01_onboarding_privacy.system.test.ts --runInBand",
    "test:system:usage": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.system.config.cjs tests/system/02_usage_ai_dashboard_analytics.system.test.ts --runInBand",
    "test:system:plan": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.system.config.cjs tests/system/03_plan_notifications_rewards.system.test.ts --runInBand",
    "test:system:delete-data": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.system.config.cjs tests/system/04_delete_my_data.system.test.ts --runInBand",

    "test:all": "npm run test:controllers && npm run test:ai",
    "test:full": "npm run test:controllers && npm run test:ai && npm run test:system"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.1",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@types/jest": "^30.0.0",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}